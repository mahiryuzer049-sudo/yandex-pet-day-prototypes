{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:local": "next dev --hostname 127.0.0.1 --port 3000",
    "build": "next build",
    "start": "next start",
    "start:local": "next start --hostname 127.0.0.1 --port 3000",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck",
    "deploy:pages": "python scripts/deploy_github_pages.py",
    "capture": "node scripts/capture-page.mjs",
    "preview:devices": "node scripts/open-device-preview.mjs",
    "preview:safari": "node scripts/open-safari-preview.mjs",
    "preview:android": "powershell -ExecutionPolicy Bypass -File scripts/open-android-emulators.ps1",
    "preview:local": "powershell -ExecutionPolicy Bypass -File scripts/open-local-preview.ps1"
  },
  "dependencies": {
    "next": "16.2.1",
    "postgres": "^3.4.8",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "playwright": "^1.58.2",
    "typescript": "^5"
  },
  "optionalDependencies": {
    "@next/swc-linux-x64-gnu": "*",
    "@next/swc-wasm-nodejs": "*"
  }
}
